# Kopiera till .env och fyll i värden. .env committas aldrig (se .gitignore).

# Delat lösenord för inloggning
VITE_PASSWORD=

# Datalager: 'github' (standard) eller 'local'.
# 'local' lagrar all data i webbläsarens localStorage och kräver varken PAT
# eller repo — bra för att köra/smoke-testa appen helt offline. Med 'local'
# ignoreras VITE_GITHUB_*-variablerna nedan.
VITE_DATA_BACKEND=github

# GitHub Personal Access Token med repo-scope (för skrivning till datafilerna)
VITE_GITHUB_PAT=

# Repo där datafilerna ligger
VITE_GITHUB_OWNER=nord-
VITE_GITHUB_REPO=vactionnode
VITE_GITHUB_BRANCH=main

# Sökvägar till datafilerna i repot
VITE_REGISTRY_PATH=data/registry.json
VITE_VACATIONS_PATH=data/vacations.json
